# ===== LLM (Ollama) =====
# ชื่อ model ที่ pull มาจาก Ollama
# ตัวเลือก: qwen2.5:1.5b | qwen2.5:7b | llama3.2:3b
MODEL_NAME=qwen2.5:1.5b

# ===== Embedding Model =====
# ดาวน์โหลดอัตโนมัติจาก HuggingFace ครั้งแรก (~1.5 GB)
EMBEDDING_MODEL=BAAI/bge-m3

# ===== Vector DB =====
VECTOR_DB_PATH=vector_db

# ===== Retriever =====
# จำนวน chunks ที่ดึงมาใช้ตอบแต่ละคำถาม
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=100
# ===== Debug =====
# true = แสดง debug log | false = ปิด (ใช้ใน production)
DEBUG=false

# ===== Database =====
# SQLite สำหรับ development
DATABASE_URL=sqlite:///./scopebot.db
# PostgreSQL สำหรับ production (uncomment บรรทัดด้านล่าง)
# DATABASE_URL=postgresql://username:password@localhost:5432/scopebot

# ===== JWT Auth =====
# เปลี่ยนเป็น random string ก่อน deploy จริง
# สร้างด้วย: openssl rand -hex 32
SECRET_KEY=scope-bot-super-secret-key-change-this-in-production
ALGORITHM=HS256
# อายุ token (นาที) — 1440 = 24 ชั่วโมง
ACCESS_TOKEN_EXPIRE_MINUTES=1440
